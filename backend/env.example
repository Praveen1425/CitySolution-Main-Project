# Environment Variables for CivicSync Backend
# Copy this file to .env and fill in your values

# JWT Secret (required)
JWT_SECRET=your-super-secret-jwt-key-here

# Optional: IPFS Integration (web3.storage)
# Get your token from: https://web3.storage/
# WEB3_STORAGE_TOKEN=your-web3-storage-token-here

# Optional: Blockchain Integration (Ethereum Sepolia Testnet)
# Get RPC URL from: https://www.alchemy.com/ or https://infura.io/
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Private key of wallet with Sepolia ETH (get test ETH from faucet)
# PRIVATE_KEY=0x1234567890abcdef...

# Contract address after deploying IncidentRegistry.sol
# CONTRACT_ADDR=0x1234567890abcdef1234567890abcdef12345678

# Server Port (optional, defaults to 5001)
# PORT=5001
